# Variáveis de ambiente — configure no painel da Vercel (não commitar o .env real!)

# Credenciais da API Pluggto
PLUGGTO_CLIENT_ID=sua_client_id_aqui
PLUGGTO_CLIENT_SECRET=sua_client_secret_aqui
PLUGGTO_USERNAME=seu_username_aqui
PLUGGTO_PASSWORD=sua_password_aqui

# Segredo JWT (gere uma string aleatória forte: openssl rand -base64 64)
JWT_SECRET=coloque_uma_string_longa_e_aleatoria_aqui

# Credenciais de acesso à aplicação
APP_EMAIL=seu@email.com
# Gere o hash com: node scripts/generate-hash.js SUA_SENHA
APP_PASSWORD_HASH=$2b$12$hash_gerado_pelo_script_aqui
